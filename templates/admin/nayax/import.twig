{% extends "layouts/admin.twig" %}
{% block title %}Nayax Import{% endblock %}
{% block page_title %}Nayax Import{% endblock %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-download me-2"></i>Import Nayax Transactions</h6>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info d-flex align-items-start mb-4">
                    <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                    <div>
                        Select a date range to import transactions from the Nayax API. Duplicate transactions will be skipped automatically.
                    </div>
                </div>

                <form method="POST" action="/nayax/import">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="date_from" class="form-label">From Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="date_from" name="date_from" required>
                        </div>
                        <div class="col-md-6">
                            <label for="date_to" class="form-label">To Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="date_to" name="date_to" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/nayax" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Nayax
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-download me-1"></i> Import Transactions
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Auto-Import Status -->
        {% if settings.nayax_auto_import %}
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <span class="badge bg-success me-2">Auto-Import Active</span>
                    <span class="text-muted">Running every {{ settings.nayax_import_interval|default(60) }} minutes, importing last {{ settings.nayax_import_days|default(7) }} days</span>
                </div>
                <p class="text-muted small mt-2 mb-0">Configure in <a href="/settings?tab=nayax">Settings &rarr; Nayax</a></p>
            </div>
        </div>
        {% else %}
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <span class="badge bg-secondary me-2">Auto-Import Disabled</span>
                    <span class="text-muted">Set up automatic imports in <a href="/settings?tab=nayax">Settings &rarr; Nayax</a></span>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Re-aggregate -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1">Re-aggregate Revenue</h6>
                    <small class="text-muted">Rebuild all Nayax revenue records from transactions. Use this if revenue amounts look incorrect.</small>
                </div>
                <form method="POST" action="/nayax/reaggregate">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <button type="submit" class="btn btn-outline-warning" onclick="return confirm('This will rebuild all Nayax revenue records. Continue?')">
                        <i class="bi bi-arrow-repeat me-1"></i> Re-aggregate
                    </button>
                </form>
            </div>
        </div>

        <!-- Recent Imports -->
        {% if recent_imports is defined and recent_imports|length > 0 %}
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Imports</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Type</th>
                                <th>Date Range</th>
                                <th class="text-center">Imported</th>
                                <th class="text-center">Skipped</th>
                                <th>Status</th>
                                <th>Imported At</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for imp in recent_imports %}
                            <tr>
                                <td><span class="badge bg-{{ imp.import_type == 'cron' ? 'info' : 'secondary' }}">{{ imp.import_type|default('manual') }}</span></td>
                                <td>{{ imp.date_from }} to {{ imp.date_to }}</td>
                                <td class="text-center"><span class="badge bg-success">{{ imp.transactions_imported }}</span></td>
                                <td class="text-center"><span class="badge bg-secondary">{{ imp.transactions_skipped }}</span></td>
                                <td><span class="badge bg-{{ imp.status == 'success' ? 'success' : (imp.status == 'failed' ? 'danger' : 'warning') }}">{{ imp.status }}</span></td>
                                <td>{{ imp.import_date }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
