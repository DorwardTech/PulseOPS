{% extends "layouts/admin.twig" %}

{% block title %}System Logs{% endblock %}
{% block page_title %}System Logs{% endblock %}

{% block head %}
<style>
    .log-viewer {
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        font-size: 0.8rem;
        line-height: 1.5;
        background: #1e1e1e;
        color: #d4d4d4;
        border-radius: 0.5rem;
        max-height: 600px;
        overflow-y: auto;
        padding: 1rem;
    }
    .log-entry { padding: 0.25rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .log-entry:hover { background: rgba(255,255,255,0.03); }
    .log-entry pre {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: inherit;
        color: inherit;
        background: none;
        border: none;
        padding: 0;
    }
    .log-level-fatal, .log-level-error { color: #f44747; }
    .log-level-warning { color: #cca700; }
    .log-level-notice { color: #3dc9b0; }
    .log-level-deprecated { color: #ce9178; }
    .log-level-info { color: #d4d4d4; }
    .log-timestamp { color: #608b4e; margin-right: 0.5rem; }
    .api-status-2xx { color: #198754; font-weight: 600; }
    .api-status-4xx { color: #fd7e14; font-weight: 600; }
    .api-status-5xx { color: #dc3545; font-weight: 600; }
    .api-status-0 { color: #6c757d; font-weight: 600; }
</style>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">System Logs</h4>
        <p class="text-muted mb-0">View PHP error logs and API request logs</p>
    </div>
</div>

{# Tab navigation #}
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link {% if tab == 'php' %}active{% endif %}" href="/logs?tab=php">
            <i class="bi bi-file-earmark-code me-1"></i> PHP Error Log
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {% if tab == 'api' %}active{% endif %}" href="/logs?tab=api">
            <i class="bi bi-cloud-arrow-down me-1"></i> Nayax API Logs
            {% if api_pagination.total_count > 0 %}
                <span class="badge bg-secondary ms-1">{{ api_pagination.total_count }}</span>
            {% endif %}
        </a>
    </li>
</ul>

{# ── PHP Error Log Tab ── #}
{% if tab == 'php' %}
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <strong>PHP Error Log</strong>
            {% if log_path != 'not found' %}
                <span class="text-muted ms-2">{{ log_path }}</span>
            {% endif %}
            {% if php_log.total_size is defined and php_log.total_size > 0 %}
                <span class="badge bg-info ms-2">{{ (php_log.total_size / 1024)|round(1) }} KB</span>
            {% endif %}
        </div>
        <div class="d-flex gap-2">
            <form method="get" action="/logs" class="d-flex gap-2">
                <input type="hidden" name="tab" value="php">
                <input type="text" name="search" value="{{ search }}" class="form-control form-control-sm"
                       placeholder="Search logs..." style="width: 200px;">
                <select name="lines" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
                    <option value="50" {% if lines == 50 %}selected{% endif %}>50 lines</option>
                    <option value="100" {% if lines == 100 %}selected{% endif %}>100 lines</option>
                    <option value="200" {% if lines == 200 %}selected{% endif %}>200 lines</option>
                    <option value="500" {% if lines == 500 %}selected{% endif %}>500 lines</option>
                </select>
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search"></i>
                </button>
            </form>
            <form method="post" action="/logs/php/clear" onsubmit="return confirm('Clear the PHP error log?')">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Clear
                </button>
            </form>
        </div>
    </div>
    <div class="card-body p-0">
        {% if php_log.source == 'unavailable' %}
            <div class="alert alert-info m-3">
                <i class="bi bi-info-circle me-2"></i>
                {{ php_log.message }}
                <br><br>
                <strong>Tip:</strong> To enable file-based logging, set <code>error_log = /var/log/php/error.log</code>
                in your <code>php.ini</code> and restart PHP.
            </div>
        {% elseif php_log.entries is empty %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle fs-1 d-block mb-2"></i>
                {% if search %}
                    No log entries matching "{{ search }}"
                {% else %}
                    No PHP errors logged. Looking good!
                {% endif %}
            </div>
        {% else %}
            <div class="log-viewer">
                {% for entry in php_log.entries %}
                <div class="log-entry log-level-{{ entry.level }}">
                    <pre>{{ entry.message }}</pre>
                </div>
                {% endfor %}
            </div>
            <div class="card-footer text-muted small">
                Showing {{ php_log.entries|length }} most recent entries (newest first)
            </div>
        {% endif %}
    </div>
</div>
{% endif %}

{# ── Nayax API Logs Tab ── #}
{% if tab == 'api' %}
<div class="card mb-4">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Nayax API Request Logs</strong>
            <form method="post" action="/logs/api/clear" class="d-flex gap-2 align-items-center"
                  onsubmit="return confirm('Delete API logs older than the selected period?')">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <label class="small text-muted mb-0">Clear older than</label>
                <select name="days" class="form-select form-select-sm" style="width: auto;">
                    <option value="7">7 days</option>
                    <option value="30" selected>30 days</option>
                    <option value="90">90 days</option>
                </select>
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Clear
                </button>
            </form>
        </div>
        {# Filters #}
        <form method="get" action="/logs" class="row g-2 align-items-end">
            <input type="hidden" name="tab" value="api">
            <div class="col-auto">
                <label class="form-label small mb-0">Method</label>
                <select name="method" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="GET" {% if filters.method == 'GET' %}selected{% endif %}>GET</option>
                    <option value="POST" {% if filters.method == 'POST' %}selected{% endif %}>POST</option>
                    <option value="PUT" {% if filters.method == 'PUT' %}selected{% endif %}>PUT</option>
                    <option value="DELETE" {% if filters.method == 'DELETE' %}selected{% endif %}>DELETE</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small mb-0">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="200" {% if filters.status == '200' %}selected{% endif %}>200 OK</option>
                    <option value="401" {% if filters.status == '401' %}selected{% endif %}>401 Unauthorized</option>
                    <option value="404" {% if filters.status == '404' %}selected{% endif %}>404 Not Found</option>
                    <option value="500" {% if filters.status == '500' %}selected{% endif %}>500 Server Error</option>
                    <option value="0" {% if filters.status == '0' %}selected{% endif %}>0 (Connection Error)</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small mb-0">Endpoint</label>
                <input type="text" name="endpoint" value="{{ filters.endpoint }}" class="form-control form-control-sm"
                       placeholder="/v1/machines...">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                <a href="/logs?tab=api" class="btn btn-sm btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        {% if api_logs is empty %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-cloud-slash fs-1 d-block mb-2"></i>
                No API log entries found.
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Time</th>
                            <th>Method</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in api_logs %}
                        <tr>
                            <td class="text-nowrap small">{{ log.created_at }}</td>
                            <td>
                                <span class="badge bg-{{ log.method == 'GET' ? 'primary' : (log.method == 'POST' ? 'success' : (log.method == 'PUT' ? 'warning' : 'danger')) }}">
                                    {{ log.method }}
                                </span>
                            </td>
                            <td class="small font-monospace">{{ log.endpoint }}</td>
                            <td>
                                {% set sc = log.status_code|default(0) %}
                                <span class="{% if sc >= 200 and sc < 300 %}api-status-2xx{% elseif sc >= 400 and sc < 500 %}api-status-4xx{% elseif sc >= 500 %}api-status-5xx{% else %}api-status-0{% endif %}">
                                    {{ sc }}
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-1" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#apilog-{{ log.id }}">
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="apilog-{{ log.id }}">
                            <td colspan="5" class="bg-light">
                                <div class="row small">
                                    <div class="col-md-6">
                                        <strong>Request:</strong>
                                        <pre class="mb-0 mt-1" style="max-height:200px;overflow:auto;">{{ log.request_data }}</pre>
                                    </div>
                                    <div class="col-md-6">
                                        <strong>Response:</strong>
                                        <pre class="mb-0 mt-1" style="max-height:200px;overflow:auto;">{{ log.response_data }}</pre>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Pagination #}
            {% if api_pagination.total_pages > 1 %}
            <nav class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                <small class="text-muted">
                    Page {{ api_pagination.current_page }} of {{ api_pagination.total_pages }}
                    ({{ api_pagination.total_count }} total)
                </small>
                <ul class="pagination pagination-sm mb-0">
                    {% if api_pagination.current_page > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="/logs?tab=api&page={{ api_pagination.current_page - 1 }}&status={{ filters.status }}&method={{ filters.method }}&endpoint={{ filters.endpoint }}">Prev</a>
                    </li>
                    {% endif %}
                    {% if api_pagination.current_page < api_pagination.total_pages %}
                    <li class="page-item">
                        <a class="page-link" href="/logs?tab=api&page={{ api_pagination.current_page + 1 }}&status={{ filters.status }}&method={{ filters.method }}&endpoint={{ filters.endpoint }}">Next</a>
                    </li>
                    {% endif %}
                </ul>
            </nav>
            {% endif %}
        {% endif %}
    </div>
</div>
{% endif %}
{% endblock %}
