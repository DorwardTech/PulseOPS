{% extends "layouts/admin.twig" %}
{% block title %}Import Revenue{% endblock %}
{% block page_title %}Import Revenue{% endblock %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-upload me-2"></i>Import Revenue from CSV</h6>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info d-flex align-items-start mb-4">
                    <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                    <div>
                        <strong>CSV Format:</strong> The CSV file should include a header row with the following columns:
                        <code>machine_id, collection_date, cash_amount, card_amount, prepaid_amount, card_transactions, prepaid_transactions, cash_source</code>
                    </div>
                </div>

                <form method="POST" action="/revenue/import" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-4">
                        <label for="csv_file" class="form-label">CSV File <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="csv_file" name="csv_file" accept=".csv,.txt" required>
                        <div class="form-text">Upload a .csv file with revenue data.</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/revenue" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Revenue
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1"></i> Import Revenue
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Sample CSV -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Sample CSV</h6>
            </div>
            <div class="card-body">
                <pre class="bg-light p-3 rounded mb-0"><code>machine_id,collection_date,cash_amount,card_amount,prepaid_amount,card_transactions,prepaid_transactions,cash_source
1,2024-01-15,150.00,75.50,20.00,12,3,manual
2,2024-01-15,200.00,100.25,0.00,15,0,nayax</code></pre>
            </div>
        </div>
    </div>
</div>
{% endblock %}
