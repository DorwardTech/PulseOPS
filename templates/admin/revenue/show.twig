{% extends "layouts/admin.twig" %}
{% block title %}Revenue Entry #{{ entry.id }}{% endblock %}
{% block page_title %}Revenue Entry #{{ entry.id }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        {% if entry.status == 'verified' %}
            <span class="badge bg-success">Verified</span>
        {% elseif entry.status == 'approved' %}
            <span class="badge bg-primary">Approved</span>
        {% else %}
            <span class="badge bg-warning text-dark">Pending</span>
        {% endif %}
        <span class="badge bg-{{ entry.source == 'nayax' ? 'info' : 'secondary' }} ms-1">{{ entry.source }}</span>
    </div>
    <div>
        <a href="/revenue/{{ entry.id }}/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        {% if entry.status == 'pending' %}
        <form method="POST" action="/revenue/{{ entry.id }}/approve" class="d-inline">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle me-1"></i> Approve
            </button>
        </form>
        {% endif %}
        <a href="/revenue" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent"><h6 class="mb-0">Collection Details</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Collection Date</dt>
                    <dd class="col-sm-7">{{ entry.collection_date }}</dd>
                    <dt class="col-sm-5">Machine</dt>
                    <dd class="col-sm-7">
                        {% if entry.machine_name %}
                            <a href="/machines/{{ entry.machine_id }}">{{ entry.machine_code }} - {{ entry.machine_name }}</a>
                        {% else %}
                            --
                        {% endif %}
                    </dd>
                    <dt class="col-sm-5">Customer</dt>
                    <dd class="col-sm-7">{{ entry.customer_name|default('--') }}</dd>
                    <dt class="col-sm-5">Source</dt>
                    <dd class="col-sm-7">{{ entry.source }}</dd>
                    <dt class="col-sm-5">Cash Source</dt>
                    <dd class="col-sm-7">{{ entry.cash_source|default('--') }}</dd>
                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">{{ entry.status }}</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent"><h6 class="mb-0">Revenue Amounts</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Cash Amount</dt>
                    <dd class="col-sm-7 text-success fw-bold">${{ entry.cash_amount|number_format(2) }}</dd>
                    <dt class="col-sm-5">Card Amount</dt>
                    <dd class="col-sm-7 text-primary fw-bold">${{ entry.card_amount|number_format(2) }}</dd>
                    <dt class="col-sm-5 fst-italic">Prepaid Amount</dt>
                    <dd class="col-sm-7 text-info fst-italic">${{ entry.prepaid_amount|number_format(2) }}</dd>
                    <dt class="col-sm-5 border-top pt-2">Gross Revenue</dt>
                    <dd class="col-sm-7 border-top pt-2 fw-bold fs-5">${{ (entry.cash_amount + entry.card_amount)|number_format(2) }}</dd>
                </dl>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent"><h6 class="mb-0">Transaction Counts</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Card Transactions</dt>
                    <dd class="col-sm-7">{{ entry.card_transactions|default(0) }}</dd>
                    <dt class="col-sm-5 fst-italic">Prepaid Transactions</dt>
                    <dd class="col-sm-7 fst-italic">{{ entry.prepaid_transactions|default(0) }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

{% if entry.notes %}
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-transparent"><h6 class="mb-0">Notes</h6></div>
    <div class="card-body">
        <p class="mb-0">{{ entry.notes }}</p>
    </div>
</div>
{% endif %}

<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-transparent"><h6 class="mb-0">Audit Trail</h6></div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Collected By</dt>
            <dd class="col-sm-9">{{ entry.created_by_name|default('--') }}</dd>
            <dt class="col-sm-3">Approved By</dt>
            <dd class="col-sm-9">{{ entry.approved_by_name|default('--') }}</dd>
            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">{{ entry.created_at|default('--') }}</dd>
            <dt class="col-sm-3">Updated</dt>
            <dd class="col-sm-9">{{ entry.updated_at|default('--') }}</dd>
        </dl>
    </div>
</div>
{% endblock %}
