{% extends "layouts/admin.twig" %}
{% block title %}{{ job.id ? 'Edit Job' : 'Create Job' }}{% endblock %}
{% block page_title %}{{ job.id ? 'Edit Job #' ~ job.id : 'Create Job' }}{% endblock %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="POST" action="{{ job.id ? '/jobs/' ~ job.id : '/jobs' }}">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-3">
                        <label for="title" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="title" value="{{ job.title }}" required>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label for="customer_id" class="form-label">Customer</label>
                            <select class="form-select" id="customer_id">
                                <option value="">-- All Customers --</option>
                                {% for customer in customers %}
                                    <option value="{{ customer.id }}">{{ customer.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="machine_id" class="form-label">Machine <span class="text-danger">*</span></label>
                            <select class="form-select" id="machine_id" name="machine_id" required>
                                <option value="">-- Select Machine --</option>
                                {% for machine in machines %}
                                    <option value="{{ machine.id }}" data-customer-id="{{ machine.customer_id }}" data-customer-name="{{ machine.customer_name }}" {{ job.machine_id == machine.id ? 'selected' }}>{{ machine.machine_code }} - {{ machine.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="status_id" class="form-label">Status <span class="text-danger">*</span></label>
                            <select class="form-select" id="status_id" name="status_id" required>
                                <option value="">-- Select Status --</option>
                                {% for status in job_statuses %}
                                    <option value="{{ status.id }}" {{ job.status_id == status.id ? 'selected' }}>{{ status.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="job_type" class="form-label">Job Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="job_type" name="job_type" required>
                                <option value="">-- Select Type --</option>
                                <option value="routine" {{ job.job_type == 'routine' ? 'selected' }}>Routine</option>
                                <option value="repair" {{ job.job_type == 'repair' ? 'selected' }}>Repair</option>
                                <option value="installation" {{ job.job_type == 'installation' ? 'selected' }}>Installation</option>
                                <option value="removal" {{ job.job_type == 'removal' ? 'selected' }}>Removal</option>
                                <option value="inspection" {{ job.job_type == 'inspection' ? 'selected' }}>Inspection</option>
                                <option value="emergency" {{ job.job_type == 'emergency' ? 'selected' }}>Emergency</option>
                                <option value="stock_fill" {{ job.job_type == 'stock_fill' ? 'selected' }}>Stock Fill</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="priority" class="form-label">Priority <span class="text-danger">*</span></label>
                            <select class="form-select" id="priority" name="priority" required>
                                <option value="low" {{ job.priority == 'low' ? 'selected' }}>Low</option>
                                <option value="normal" {{ (job.priority == 'normal' or not job.priority) ? 'selected' }}>Normal</option>
                                <option value="high" {{ job.priority == 'high' ? 'selected' }}>High</option>
                                <option value="urgent" {{ job.priority == 'urgent' ? 'selected' }}>Urgent</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="4">{{ job.description }}</textarea>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="assigned_to" class="form-label">Assigned To</label>
                            <select class="form-select" id="assigned_to" name="assigned_to">
                                <option value="">-- Unassigned --</option>
                                {% for user in users %}
                                    <option value="{{ user.id }}" {{ job.assigned_to == user.id ? 'selected' }}>{{ user.full_name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="scheduled_date" class="form-label">Scheduled Date</label>
                            <input type="date" class="form-control" id="scheduled_date" name="scheduled_date" value="{{ job.scheduled_date }}">
                        </div>
                        <div class="col-md-3">
                            <label for="scheduled_time" class="form-label">Scheduled Time</label>
                            <input type="time" class="form-control" id="scheduled_time" name="scheduled_time" value="{{ job.scheduled_time }}">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label for="labour_minutes" class="form-label">Labour (minutes)</label>
                            <input type="number" class="form-control" id="labour_minutes" name="labour_minutes" value="{{ job.labour_minutes }}" min="0" step="1">
                        </div>
                        <div class="col-md-4">
                            <label for="labour_rate" class="form-label">Labour Rate ($/hr)</label>
                            <input type="number" class="form-control" id="labour_rate" name="labour_rate" value="{{ job.labour_rate }}" min="0" step="0.01">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Estimated Cost</label>
                            <div class="form-control bg-light" id="labourCostDisplay">$0.00</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="is_customer_visible" name="is_customer_visible" value="1" {{ job.is_customer_visible ? 'checked' }}>
                            <label class="form-check-label" for="is_customer_visible">
                                Visible to customer
                            </label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/jobs" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> {{ job.id ? 'Update Job' : 'Create Job' }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function calcLabourCost() {
        const mins = parseFloat(document.getElementById('labour_minutes').value) || 0;
        const rate = parseFloat(document.getElementById('labour_rate').value) || 0;
        const cost = (mins / 60) * rate;
        document.getElementById('labourCostDisplay').textContent = '$' + cost.toFixed(2);
    }
    document.getElementById('labour_minutes').addEventListener('input', calcLabourCost);
    document.getElementById('labour_rate').addEventListener('input', calcLabourCost);
    calcLabourCost();

    // Customer <-> Machine interaction
    const customerSelect = document.getElementById('customer_id');
    const machineSelect = document.getElementById('machine_id');
    const allMachineOptions = Array.from(machineSelect.querySelectorAll('option[value]'));

    // When customer changes, filter machines
    customerSelect.addEventListener('change', function() {
        const custId = this.value;
        const currentVal = machineSelect.value;
        machineSelect.innerHTML = '<option value="">-- Select Machine --</option>';
        allMachineOptions.forEach(opt => {
            if (!custId || opt.dataset.customerId === custId) {
                machineSelect.appendChild(opt.cloneNode(true));
            }
        });
        // Restore selection if still valid
        if (machineSelect.querySelector('option[value="' + currentVal + '"]')) {
            machineSelect.value = currentVal;
        }
    });

    // When machine changes, auto-select customer
    machineSelect.addEventListener('change', function() {
        const selected = this.options[this.selectedIndex];
        if (selected && selected.dataset.customerId) {
            customerSelect.value = selected.dataset.customerId;
        }
    });

    // On page load, if machine is pre-selected, set customer
    (function() {
        const selected = machineSelect.options[machineSelect.selectedIndex];
        if (selected && selected.dataset.customerId) {
            customerSelect.value = selected.dataset.customerId;
        }
    })();
</script>
{% endblock %}
