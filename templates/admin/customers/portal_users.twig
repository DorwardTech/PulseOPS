{% extends "layouts/admin.twig" %}
{% block title %}Portal Users - {{ customer.name }}{% endblock %}
{% block page_title %}Portal Users{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="text-muted">Customer:</span>
        <a href="/customers/{{ customer.id }}">{{ customer.name }}</a>
    </div>
    <div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPortalUserModal">
            <i class="bi bi-plus-lg me-1"></i> Add Portal User
        </button>
        <a href="/customers/{{ customer.id }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Customer
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in portal_users %}
                    <tr>
                        <td>{{ user.name }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% if user.is_active %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-secondary">Disabled</span>
                            {% endif %}
                        </td>
                        <td>{{ user.created_at }}</td>
                        <td class="text-end">
                            <form method="POST" action="/customers/{{ customer.id }}/portal-users/{{ user.id }}/toggle" class="d-inline">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm btn-outline-{{ user.is_active ? 'warning' : 'success' }}">
                                    {{ user.is_active ? 'Disable' : 'Enable' }}
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No portal users configured.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Portal User Modal -->
<div class="modal fade" id="addPortalUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/customers/{{ customer.id }}/portal-users">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title">Add Portal User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="portal_name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="portal_name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="portal_email" class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="portal_email" name="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="portal_password" class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="portal_password" name="password" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add User</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
