{% extends "layouts/admin.twig" %}
{% block title %}Customer: {{ customer.name }}{% endblock %}
{% block page_title %}{{ customer.name }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        {% if customer.is_active %}
            <span class="badge bg-success">Active</span>
        {% else %}
            <span class="badge bg-secondary">Inactive</span>
        {% endif %}
    </div>
    <div>
        <a href="/customers/{{ customer.id }}/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a href="/customers" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#overview" type="button">Overview</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#machines" type="button">Machines</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#revenue" type="button">Revenue</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#commissions" type="button">Commissions</button>
    </li>
</ul>

<div class="tab-content">
    <!-- Overview Tab -->
    <div class="tab-pane fade show active" id="overview">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Contact Information</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Business Name</dt>
                            <dd class="col-sm-7">{{ customer.name }}</dd>
                            <dt class="col-sm-5">Contact Name</dt>
                            <dd class="col-sm-7">{{ customer.contact_name|default('--') }}</dd>
                            <dt class="col-sm-5">Email</dt>
                            <dd class="col-sm-7">{% if customer.email %}<a href="mailto:{{ customer.email }}">{{ customer.email }}</a>{% else %}--{% endif %}</dd>
                            <dt class="col-sm-5">Phone</dt>
                            <dd class="col-sm-7">{{ customer.phone|default('--') }}</dd>
                            <dt class="col-sm-5">Address</dt>
                            <dd class="col-sm-7">
                                {{ customer.address_line1|default('') }}<br>
                                {% if customer.address_line2 %}{{ customer.address_line2 }}<br>{% endif %}
                                {{ customer.city|default('') }} {{ customer.state|default('') }} {{ customer.postcode|default('') }}
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Commission Settings</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Commission Rate</dt>
                            <dd class="col-sm-7">{{ customer.commission_rate is not null ? customer.commission_rate ~ '%' : 'Default' }}</dd>
                            <dt class="col-sm-5">Processing Fee</dt>
                            <dd class="col-sm-7">{{ customer.processing_fee is not null ? format_currency(customer.processing_fee) : 'Default' }}</dd>
                        </dl>
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Bank Details</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Bank Name</dt>
                            <dd class="col-sm-7">{{ customer.bank_name|default('--') }}</dd>
                            <dt class="col-sm-5">Account Name</dt>
                            <dd class="col-sm-7">{{ customer.bank_account_name|default('--') }}</dd>
                            <dt class="col-sm-5">BSB</dt>
                            <dd class="col-sm-7">{{ customer.bank_bsb|default('--') }}</dd>
                            <dt class="col-sm-5">Account Number</dt>
                            <dd class="col-sm-7">{{ customer.bank_account_number|default('--') }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Portal Users -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Portal Users</h6>
                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addPortalUserModal">
                    <i class="bi bi-plus-lg me-1"></i> Add Portal User
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in portal_users %}
                            <tr>
                                <td>{{ user.name }}</td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% if user.is_active %}
                                        <span class="badge bg-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Disabled</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <form method="POST" action="/customers/{{ customer.id }}/portal/{{ user.id }}/toggle" class="d-inline">
                                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="btn btn-sm btn-outline-{{ user.is_active ? 'warning' : 'success' }}">
                                            {{ user.is_active ? 'Disable' : 'Enable' }}
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No portal users configured.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Add Portal User Modal -->
        <div class="modal fade" id="addPortalUserModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="POST" action="/customers/{{ customer.id }}/portal">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <div class="modal-header">
                            <h5 class="modal-title">Add Portal User</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="portal_name" class="form-label">Full Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="portal_name" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="portal_email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="portal_email" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="portal_password" class="form-label">Password <span class="text-danger">*</span></label>
                                <input type="password" class="form-control" id="portal_password" name="password" required>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Add User</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Machines Tab -->
    <div class="tab-pane fade" id="machines">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Machines</h6>
                <a href="/machines/create?customer_id={{ customer.id }}" class="btn btn-sm btn-outline-primary">Add Machine</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Location</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for machine in machines %}
                            <tr>
                                <td><strong>{{ machine.machine_code }}</strong></td>
                                <td>{{ machine.name }}</td>
                                <td>{{ machine.type_name|default('--') }}</td>
                                <td>
                                    {% if machine.status == 'active' %}
                                        <span class="badge bg-success">Active</span>
                                    {% elseif machine.status == 'maintenance' %}
                                        <span class="badge bg-warning text-dark">Maintenance</span>
                                    {% elseif machine.status == 'inactive' %}
                                        <span class="badge bg-secondary">Inactive</span>
                                    {% elseif machine.status == 'in_storage' %}
                                        <span class="badge bg-info">In Storage</span>
                                    {% endif %}
                                </td>
                                <td>{{ machine.location_details|default('--') }}</td>
                                <td class="text-end">
                                    <a href="/machines/{{ machine.id }}" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No machines assigned to this customer.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Tab -->
    <div class="tab-pane fade" id="revenue">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Revenue Summary</h6>
                <a href="/revenue?customer_id={{ customer.id }}" class="btn btn-sm btn-outline-primary">View All Revenue</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Machine</th>
                                <th class="text-end">Cash</th>
                                <th class="text-end">Card</th>
                                <th class="text-end fst-italic text-info">Prepaid</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in revenue_entries %}
                            <tr>
                                <td>{{ format_date(entry.collection_date) }}</td>
                                <td>{{ entry.machine_name|default('--') }}</td>
                                <td class="text-end">{{ format_currency(entry.cash_amount) }}</td>
                                <td class="text-end">{{ format_currency(entry.card_amount) }}</td>
                                <td class="text-end fst-italic text-info">{{ format_currency(entry.prepaid_amount) }}</td>
                                <td class="text-end"><strong>{{ format_currency(entry.cash_amount + entry.card_amount) }}</strong></td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No revenue entries found.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Commissions Tab -->
    <div class="tab-pane fade" id="commissions">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Commission History</h6>
                <a href="/commissions?customer_id={{ customer.id }}" class="btn btn-sm btn-outline-primary">View All Commissions</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Period</th>
                                <th class="text-end">Gross Revenue</th>
                                <th class="text-end">Net Revenue</th>
                                <th class="text-end">Commission</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for commission in commissions %}
                            <tr>
                                <td>{{ format_date(commission.period_start) }} - {{ format_date(commission.period_end) }}</td>
                                <td class="text-end">{{ format_currency(commission.gross_revenue) }}</td>
                                <td class="text-end">{{ format_currency(commission.net_revenue) }}</td>
                                <td class="text-end"><strong>{{ format_currency(commission.commission_amount) }}</strong></td>
                                <td>
                                    {% if commission.status == 'draft' %}
                                        <span class="badge bg-secondary">Draft</span>
                                    {% elseif commission.status == 'approved' %}
                                        <span class="badge bg-primary">Approved</span>
                                    {% elseif commission.status == 'paid' %}
                                        <span class="badge bg-success">Paid</span>
                                    {% elseif commission.status == 'void' %}
                                        <span class="badge bg-danger">Void</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <a href="/commissions/{{ commission.id }}" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No commissions found.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
