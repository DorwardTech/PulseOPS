{% extends "layouts/admin.twig" %}
{% block title %}Job Status Management{% endblock %}
{% block page_title %}Job Status Management{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <a href="/settings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back to Settings
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Status Name</th>
                        <th>Slug</th>
                        <th>Color</th>
                        <th>Preview</th>
                        <th class="text-center">Order</th>
                        <th class="text-center">Jobs</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for status in statuses %}
                    <tr>
                        <td><strong>{{ status.name }}</strong></td>
                        <td><code>{{ status.slug }}</code></td>
                        <td><code>{{ status.color }}</code></td>
                        <td><span class="badge" style="background-color: {{ status.color }}">{{ status.name }}</span></td>
                        <td class="text-center">{{ status.sort_order }}</td>
                        <td class="text-center"><span class="badge bg-primary rounded-pill">{{ status.job_count|default(0) }}</span></td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editStatusModal{{ status.id }}">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="POST" action="/settings/job-statuses/{{ status.id }}/delete" class="d-inline" onsubmit="return confirm('Delete this status?')">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>

                    <!-- Edit Status Modal -->
                    <div class="modal fade" id="editStatusModal{{ status.id }}" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form method="POST" action="/settings/job-statuses/{{ status.id }}">
                                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Edit Job Status</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" name="name" value="{{ status.name }}" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Slug</label>
                                            <input type="text" class="form-control" name="slug" value="{{ status.slug }}">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Color</label>
                                            <input type="color" class="form-control form-control-color" name="color" value="{{ status.color }}">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Sort Order</label>
                                            <input type="number" class="form-control" name="sort_order" value="{{ status.sort_order }}" min="0">
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="is_default" value="1" {{ status.is_default ? 'checked' }}>
                                            <label class="form-check-label">Default Status</label>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary">Save</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-transparent">
        <form method="POST" action="/settings/job-statuses" class="row g-2 align-items-end">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <div class="col-md-3">
                <label class="form-label small">Status Name</label>
                <input type="text" class="form-control form-control-sm" name="name" required>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Slug</label>
                <input type="text" class="form-control form-control-sm" name="slug">
            </div>
            <div class="col-md-2">
                <label class="form-label small">Color</label>
                <input type="color" class="form-control form-control-color form-control-sm" name="color" value="#6b7280">
            </div>
            <div class="col-md-2">
                <label class="form-label small">Order</label>
                <input type="number" class="form-control form-control-sm" name="sort_order" value="0" min="0">
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-sm btn-primary w-100">Add Status</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
