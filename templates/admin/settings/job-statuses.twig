{% extends "layouts/admin.twig" %}
{% block title %}Job Statuses{% endblock %}
{% block page_title %}Job Status Management{% endblock %}
{% block content %}
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Name</th><th>Slug</th><th>Color</th><th>Default</th><th>Completed</th><th>Order</th></tr></thead>
                <tbody>
                {% for status in statuses %}
                <tr>
                    <td><span class="badge" style="background-color: {{ status.color }}">{{ status.name }}</span></td>
                    <td><code>{{ status.slug }}</code></td>
                    <td>{{ status.color }}</td>
                    <td>{% if status.is_default %}<i class="bi bi-check-lg text-success"></i>{% endif %}</td>
                    <td>{% if status.is_completed %}<i class="bi bi-check-lg text-success"></i>{% endif %}</td>
                    <td>{{ status.sort_order }}</td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
