{% extends "layouts/admin.twig" %}
{% block title %}Purge Data{% endblock %}
{% block page_title %}Purge Data{% endblock %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        {% if flash_success %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ flash_success }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}
        {% if flash_error %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ flash_error }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Warning:</strong> Purging data is permanent and cannot be undone. Please ensure you have a backup before proceeding.
        </div>

        <form method="POST" action="/settings/purge-data" id="purgeForm">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent">
                    <h6 class="mb-0"><i class="bi bi-trash me-2"></i>Select Data to Purge</h6>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="targets[]" value="revenue" id="purge_revenue">
                        <label class="form-check-label" for="purge_revenue">
                            <strong>Revenue Records</strong>
                            <span class="text-muted ms-2">({{ counts.revenue }} records)</span>
                        </label>
                        <div class="form-text">Removes all revenue entries including manual and Nayax-sourced records.</div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="targets[]" value="commission_payments" id="purge_commissions">
                        <label class="form-check-label" for="purge_commissions">
                            <strong>Commission Payments</strong>
                            <span class="text-muted ms-2">({{ counts.commission_payments }} records)</span>
                        </label>
                        <div class="form-text">Removes all commission payments and their associated line items.</div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="targets[]" value="commission_line_items" id="purge_line_items">
                        <label class="form-check-label" for="purge_line_items">
                            <strong>Commission Line Items</strong>
                            <span class="text-muted ms-2">({{ counts.commission_line_items }} records)</span>
                        </label>
                        <div class="form-text">Removes all commission line items (adjustments, bonuses, deductions).</div>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="targets[]" value="nayax_transactions" id="purge_nayax">
                        <label class="form-check-label" for="purge_nayax">
                            <strong>Nayax Transactions</strong>
                            <span class="text-muted ms-2">({{ counts.nayax_transactions }} records)</span>
                        </label>
                        <div class="form-text">Removes all imported Nayax transactions. This allows re-importing and re-aggregating fresh data.</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm border-danger mb-4">
                <div class="card-header bg-transparent">
                    <h6 class="mb-0 text-danger"><i class="bi bi-shield-exclamation me-2"></i>Confirm Purge</h6>
                </div>
                <div class="card-body">
                    <p class="mb-3">Type <strong>PURGE</strong> below to confirm you want to permanently delete the selected data.</p>
                    <input type="text" class="form-control" name="confirm" id="confirmInput" placeholder="Type PURGE to confirm" autocomplete="off">
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/settings" class="btn btn-outline-secondary">Back to Settings</a>
                <button type="submit" class="btn btn-danger" id="purgeBtn" disabled>
                    <i class="bi bi-trash me-1"></i> Purge Selected Data
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.getElementById('confirmInput').addEventListener('input', function() {
    document.getElementById('purgeBtn').disabled = this.value !== 'PURGE';
});

document.getElementById('purgeForm').addEventListener('submit', function(e) {
    var checked = document.querySelectorAll('input[name="targets[]"]:checked');
    if (checked.length === 0) {
        e.preventDefault();
        alert('Please select at least one data type to purge.');
        return;
    }
    if (!confirm('Are you absolutely sure? This action cannot be undone.')) {
        e.preventDefault();
    }
});
</script>
{% endblock %}
