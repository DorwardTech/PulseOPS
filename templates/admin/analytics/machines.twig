{% extends "layouts/admin.twig" %}
{% block title %}Machine Analytics{% endblock %}
{% block page_title %}Machine Analytics{% endblock %}
{% block content %}
<!-- Date Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" action="/analytics/machines" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" name="date_from" class="form-control" value="{{ filters.date_from }}">
            </div>
            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" name="date_to" class="form-control" value="{{ filters.date_to }}">
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
            <div class="col-md-3">
                <a href="/analytics/export?type=machines&date_from={{ filters.date_from }}&date_to={{ filters.date_to }}" class="btn btn-outline-success w-100">
                    <i class="bi bi-download me-1"></i> Export CSV
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Status Distribution -->
<div class="row g-3 mb-4">
    {% for stat in status_distribution %}
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="text-muted small mb-1 text-capitalize">{{ stat.status|replace({'_': ' '}) }}</div>
                <h4 class="mb-0">{{ stat.count }}</h4>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

<!-- Machine Revenue Table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent">
        <h6 class="mb-0">Machine Performance</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 sortable">
                <thead class="table-light">
                    <tr>
                        <th>Machine</th>
                        <th>Customer</th>
                        <th>Status</th>
                        <th class="text-center">Collections</th>
                        <th class="text-end">Cash</th>
                        <th class="text-end">Card</th>
                        <th class="text-end">Total Revenue</th>
                        <th>Last Collection</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in machine_revenue %}
                    <tr>
                        <td><a href="/machines/{{ row.id }}">{{ row.machine_code }} - {{ row.name }}</a></td>
                        <td>{{ row.customer_name|default('--') }}</td>
                        <td>
                            {% if row.status == 'active' %}
                                <span class="badge bg-success">Active</span>
                            {% elseif row.status == 'maintenance' %}
                                <span class="badge bg-warning text-dark">Maintenance</span>
                            {% elseif row.status == 'inactive' %}
                                <span class="badge bg-secondary">Inactive</span>
                            {% elseif row.status == 'in_storage' %}
                                <span class="badge bg-info">In Storage</span>
                            {% endif %}
                        </td>
                        <td class="text-center">{{ row.collection_count }}</td>
                        <td class="text-end">${{ row.cash_total|number_format(2) }}</td>
                        <td class="text-end">${{ row.card_total|number_format(2) }}</td>
                        <td class="text-end fw-bold">${{ row.total_revenue|number_format(2) }}</td>
                        <td>{{ row.last_collection|default('--') }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No machine data available.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Collection Frequency -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
        <h6 class="mb-0">Collection Frequency (Avg. Days Between Collections)</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 sortable">
                <thead class="table-light">
                    <tr>
                        <th>Machine</th>
                        <th class="text-center">Total Collections</th>
                        <th>First Collection</th>
                        <th>Last Collection</th>
                        <th class="text-end">Avg. Days Between</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in collection_frequency %}
                    <tr>
                        <td><a href="/machines/{{ row.id }}">{{ row.machine_code }} - {{ row.name }}</a></td>
                        <td class="text-center">{{ row.total_collections }}</td>
                        <td>{{ row.first_collection }}</td>
                        <td>{{ row.last_collection }}</td>
                        <td class="text-end">{{ row.avg_days_between|number_format(1) }} days</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Not enough data to calculate frequency.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
