{% extends "layouts/admin.twig" %}
{% block title %}Machine: {{ machine.name }}{% endblock %}
{% block page_title %}{{ machine.name }}{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="text-muted">{{ machine.machine_code }}</span>
        {% if machine.status == 'active' %}
            <span class="badge bg-success ms-2">Active</span>
        {% elseif machine.status == 'maintenance' %}
            <span class="badge bg-warning text-dark ms-2">Maintenance</span>
        {% elseif machine.status == 'inactive' %}
            <span class="badge bg-secondary ms-2">Inactive</span>
        {% elseif machine.status == 'in_storage' %}
            <span class="badge bg-info ms-2">In Storage</span>
        {% endif %}
    </div>
    <div>
        <a href="/machines/{{ machine.id }}/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a href="/machines" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#overview" type="button">Overview</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#revenue" type="button">Revenue</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#jobs" type="button">Jobs</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#photos" type="button">Photos</button>
    </li>
    {% if nayax_device %}
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#nayax" type="button">Nayax</button>
    </li>
    {% endif %}
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#history" type="button">History</button>
    </li>
</ul>

<div class="tab-content">
    <!-- Overview Tab -->
    <div class="tab-pane fade show active" id="overview">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Machine Details</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Machine Code</dt>
                            <dd class="col-sm-7">{{ machine.machine_code }}</dd>
                            <dt class="col-sm-5">Name</dt>
                            <dd class="col-sm-7">{{ machine.name }}</dd>
                            <dt class="col-sm-5">Type</dt>
                            <dd class="col-sm-7">{{ machine.type_name|default('--') }}</dd>
                            <dt class="col-sm-5">Serial Number</dt>
                            <dd class="col-sm-7">{{ machine.serial_number|default('--') }}</dd>
                            <dt class="col-sm-5">Manufacturer</dt>
                            <dd class="col-sm-7">{{ machine.manufacturer|default('--') }}</dd>
                            <dt class="col-sm-5">Model</dt>
                            <dd class="col-sm-7">{{ machine.model|default('--') }}</dd>
                            <dt class="col-sm-5">Installation Date</dt>
                            <dd class="col-sm-7">{{ machine.installation_date ? format_date(machine.installation_date) : '--' }}</dd>
                            <dt class="col-sm-5">Nayax Cash Counting</dt>
                            <dd class="col-sm-7">{{ machine.nayax_cash_counting ? 'Enabled' : 'Disabled' }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Customer</h6></div>
                    <div class="card-body">
                        {% if machine.customer_id %}
                            <p class="mb-1"><strong><a href="/customers/{{ machine.customer_id }}">{{ machine.customer_name }}</a></strong></p>
                            <p class="mb-1 text-muted">{{ machine.customer_email|default('') }}</p>
                            <p class="mb-0 text-muted">{{ machine.customer_phone|default('') }}</p>
                        {% else %}
                            <p class="text-muted mb-0">No customer assigned.</p>
                        {% endif %}
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Location &amp; Notes</h6></div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Location:</strong> {{ machine.location_details|default('Not specified') }}</p>
                        <p class="mb-0"><strong>Notes:</strong> {{ machine.notes|default('No notes') }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Tab -->
    <div class="tab-pane fade" id="revenue">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Recent Revenue</h6>
                <a href="/revenue?machine_id={{ machine.id }}" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th class="text-end">Cash</th>
                                <th class="text-end">Card</th>
                                <th class="text-end fst-italic text-info">Prepaid</th>
                                <th>Source</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in revenue_entries %}
                            <tr>
                                <td>{{ format_date(entry.collection_date) }}</td>
                                <td class="text-end">{{ format_currency(entry.cash_amount) }}</td>
                                <td class="text-end">{{ format_currency(entry.card_amount) }}</td>
                                <td class="text-end fst-italic text-info">{{ format_currency(entry.prepaid_amount) }}</td>
                                <td>{{ entry.source }}</td>
                                <td><span class="badge bg-{{ entry.status == 'verified' ? 'success' : 'warning' }}">{{ entry.status }}</span></td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No revenue entries found.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Jobs Tab -->
    <div class="tab-pane fade" id="jobs">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Maintenance Jobs</h6>
                <a href="/jobs/create?machine_id={{ machine.id }}" class="btn btn-sm btn-outline-primary">Create Job</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Job #</th>
                                <th>Title</th>
                                <th>Status</th>
                                <th>Priority</th>
                                <th>Scheduled</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for job in jobs %}
                            <tr>
                                <td><strong>#{{ job.id }}</strong></td>
                                <td>{{ job.title }}</td>
                                <td><span class="badge" style="background-color: {{ job.status_color|default('#6c757d') }}">{{ job.status_name|default(job.status) }}</span></td>
                                <td>
                                    {% if job.priority == 'high' %}
                                        <span class="badge bg-danger">High</span>
                                    {% elseif job.priority == 'medium' %}
                                        <span class="badge bg-warning text-dark">Medium</span>
                                    {% else %}
                                        <span class="badge bg-info">Low</span>
                                    {% endif %}
                                </td>
                                <td>{{ job.scheduled_date ? format_date(job.scheduled_date) : '--' }}</td>
                                <td class="text-end">
                                    <a href="/jobs/{{ job.id }}" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No jobs found.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Photos Tab -->
    <div class="tab-pane fade" id="photos">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h6 class="mb-0">Photos</h6>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-4">
                    {% for photo in photos %}
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm">
                            <img src="{{ photo.file_path }}" class="card-img-top" alt="{{ photo.description|default('Machine photo') }}" style="height: 180px; object-fit: cover;">
                            <div class="card-body p-2 text-center">
                                <small class="text-muted">{{ photo.description|default('') }}</small>
                                <form method="POST" action="/machines/{{ machine.id }}/photos/{{ photo.id }}/delete" class="mt-1">
                                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this photo?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="col-12">
                        <p class="text-muted text-center">No photos uploaded yet.</p>
                    </div>
                    {% endfor %}
                </div>

                <!-- Upload Form -->
                <form method="POST" action="/machines/{{ machine.id }}/photos" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label for="photo" class="form-label">Upload Photo</label>
                            <input type="file" class="form-control" id="photo" name="photo" accept="image/*" required>
                        </div>
                        <div class="col-md-5">
                            <label for="caption" class="form-label">Caption</label>
                            <input type="text" class="form-control" id="caption" name="caption" placeholder="Optional caption">
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-upload me-1"></i> Upload
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Nayax Tab -->
    {% if nayax_device %}
    <div class="tab-pane fade" id="nayax">
        <!-- Status & Version -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Device Status</h6></div>
                    <div class="card-body text-center">
                        {% if nayax_device.device_status == 'online' or nayax_device.device_status == '1' %}
                            <span class="badge bg-success fs-6 mb-2">Online</span>
                        {% else %}
                            <span class="badge bg-danger fs-6 mb-2">Offline</span>
                        {% endif %}
                        <p class="text-muted small mb-0">Last Communication: {{ nayax_device.last_communication ? format_datetime(nayax_device.last_communication) : 'Never' }}</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0">Device Version</h6></div>
                    <div class="card-body text-center">
                        <span class="fs-5 fw-bold">{{ nayax_device.firmware_version|default('--') }}</span>
                        <p class="text-muted small mb-0">Firmware Version</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hardware Details -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0"><i class="bi bi-cpu me-2"></i>Hardware</h6></div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Nayax Machine ID</dt>
                            <dd class="col-sm-7">{{ nayax_device.nayax_device_id|default('--') }}</dd>
                            <dt class="col-sm-5">Device ID</dt>
                            <dd class="col-sm-7">{{ nayax_device.device_id|default('--') }}</dd>
                            <dt class="col-sm-5">Device Serial</dt>
                            <dd class="col-sm-7">{{ nayax_device.device_serial|default('--') }}</dd>
                            <dt class="col-sm-5">Device Model</dt>
                            <dd class="col-sm-7">{{ nayax_device.device_model|default('--') }}</dd>
                            <dt class="col-sm-5">Device Name</dt>
                            <dd class="col-sm-7">{{ nayax_device.device_name|default('--') }}</dd>
                            <dt class="col-sm-5">Smart Sticker ID</dt>
                            <dd class="col-sm-7">{{ nayax_device.smart_sticker_id|default('--') }}</dd>
                            <dt class="col-sm-5">VPOS</dt>
                            <dd class="col-sm-7">{{ nayax_device.vpos_id|default('--') }}</dd>
                            <dt class="col-sm-5">Cash Box ID</dt>
                            <dd class="col-sm-7">{{ nayax_device.cash_box_id|default('--') }}</dd>
                            <dt class="col-sm-5">Last Synced</dt>
                            <dd class="col-sm-7">{{ nayax_device.last_sync_at ? format_datetime(nayax_device.last_sync_at) : 'Never' }}</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- Location -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent"><h6 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Location</h6></div>
                    <div class="card-body">
                        {% if nayax_device.latitude and nayax_device.longitude %}
                            <div class="mb-3" style="height: 250px; border-radius: 8px; overflow: hidden;">
                                <iframe
                                    width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0"
                                    src="https://www.openstreetmap.org/export/embed.html?bbox={{ nayax_device.longitude - 0.005 }}%2C{{ nayax_device.latitude - 0.005 }}%2C{{ nayax_device.longitude + 0.005 }}%2C{{ nayax_device.latitude + 0.005 }}&layer=mapnik&marker={{ nayax_device.latitude }}%2C{{ nayax_device.longitude }}"
                                    style="border: 0;">
                                </iframe>
                            </div>
                            <p class="small text-muted mb-0">
                                <i class="bi bi-geo me-1"></i>{{ nayax_device.latitude }}, {{ nayax_device.longitude }}
                            </p>
                        {% else %}
                            <p class="text-muted mb-0">No GPS coordinates available.</p>
                            {% if machine.location_details %}
                                <p class="mt-2 mb-0"><strong>Location:</strong> {{ machine.location_details }}</p>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-receipt me-2"></i>Recent Transactions</h6>
                <a href="/nayax/transactions?device_id={{ nayax_device.device_id }}" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date/Time</th>
                                <th>Transaction ID</th>
                                <th>Payment Type</th>
                                <th class="text-end">Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for txn in nayax_transactions %}
                            <tr>
                                <td class="text-nowrap">{{ format_datetime(txn.transaction_date) }}</td>
                                <td><code>{{ txn.transaction_id }}</code></td>
                                <td>
                                    {% if txn.payment_type == 'card' or txn.payment_type == 'credit' %}
                                        <span class="badge bg-primary">Card</span>
                                    {% elseif txn.payment_type == 'cash' %}
                                        <span class="badge bg-success">Cash</span>
                                    {% elseif txn.payment_type == 'prepaid' %}
                                        <span class="badge bg-info">Prepaid</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ txn.payment_type }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end fw-bold">{{ format_currency(txn.amount) }}</td>
                                <td>
                                    <span class="badge bg-{{ txn.status == 'completed' ? 'success' : 'warning' }}">{{ txn.status }}</span>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No transactions found.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- History Tab -->
    <div class="tab-pane fade" id="history">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h6 class="mb-0">Activity History</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Changes</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in activity_logs %}
                            <tr>
                                <td class="text-nowrap">{{ format_datetime(log.created_at) }}</td>
                                <td>{{ log.user_name|default('System') }}</td>
                                <td>
                                    {% if log.action == 'created' %}
                                        <span class="badge bg-success">Created</span>
                                    {% elseif log.action == 'updated' %}
                                        <span class="badge bg-primary">Updated</span>
                                    {% elseif log.action == 'deleted' %}
                                        <span class="badge bg-danger">Deleted</span>
                                    {% elseif log.action == 'nayax_device_linked' %}
                                        <span class="badge bg-info">Nayax Linked</span>
                                    {% elseif log.action == 'nayax_device_unlinked' %}
                                        <span class="badge bg-warning text-dark">Nayax Unlinked</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ log.action|replace({'_': ' '})|title }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if log.changes %}
                                        {% for field, vals in log.changes %}
                                            <div class="small">
                                                <strong>{{ field|replace({'_': ' '})|title }}:</strong>
                                                {% if vals.from is defined %}
                                                    <span class="text-danger">{{ vals.from ?? 'empty' }}</span>
                                                    <i class="bi bi-arrow-right mx-1"></i>
                                                    <span class="text-success">{{ vals.to ?? 'empty' }}</span>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    {% elseif log.action == 'created' %}
                                        <span class="text-muted small">Machine created</span>
                                    {% elseif log.action == 'deleted' %}
                                        <span class="text-muted small">Machine deleted</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No activity recorded yet.</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
