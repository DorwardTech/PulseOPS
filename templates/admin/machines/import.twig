{% extends "layouts/admin.twig" %}
{% block title %}Import Machines{% endblock %}
{% block page_title %}Import Machines{% endblock %}
{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-upload me-2"></i>Import Machines from CSV</h6>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info d-flex align-items-start mb-4">
                    <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                    <div>
                        <strong>CSV Format:</strong> The CSV file should include a header row. Required: <code>machine_code, name</code>.
                        Optional: <code>customer</code> (name), <code>machine_type</code> (name), <code>description, location_details, status</code> (active/maintenance/inactive/in_storage), <code>serial_number, manufacturer, model</code>.
                        <br><small class="text-muted">You can use customer and machine type names instead of IDs. IDs are also accepted.</small>
                    </div>
                </div>

                <form method="POST" action="/machines/import" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-4">
                        <label for="csv_file" class="form-label">CSV File <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="csv_file" name="csv_file" accept=".csv,.txt" required>
                        <div class="form-text">Upload a .csv file with machine data.</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/machines" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Machines
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1"></i> Import Machines
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Sample CSV -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Sample CSV</h6>
            </div>
            <div class="card-body">
                <pre class="bg-light p-3 rounded mb-0"><code>machine_code,name,customer,machine_type,description,location_details,status,serial_number,manufacturer,model
MC001,Vending Machine A,Acme Corp,Snack,Main lobby machine,Building A Ground Floor,active,SN12345,VendCo,Model X
MC002,Vending Machine B,Acme Corp,Drink,Break room machine,Building A Level 2,maintenance,SN12346,VendCo,Model Y</code></pre>
            </div>
        </div>
    </div>
</div>
{% endblock %}
