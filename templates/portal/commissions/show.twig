{% extends "layouts/portal.twig" %}

{% block title %}Commission - {{ commission.period_label|default(format_date(commission.period_start) ~ ' - ' ~ format_date(commission.period_end)) }}{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portal/commissions" class="text-decoration-none">Commissions</a></li>
        <li class="breadcrumb-item active">{{ commission.period_label|default(format_date(commission.period_start) ~ ' - ' ~ format_date(commission.period_end)) }}</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Commission Summary -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Commission Summary</h5>
                {% if commission.status == 'draft' %}
                    <span class="badge bg-secondary">Draft</span>
                {% elseif commission.status == 'approved' %}
                    <span class="badge bg-primary">Approved</span>
                {% elseif commission.status == 'paid' %}
                    <span class="badge bg-success">Paid</span>
                {% elseif commission.status == 'void' %}
                    <span class="badge bg-danger">Void</span>
                {% endif %}
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted ps-3">Period</th>
                            <td class="text-end pe-3">{{ commission.period_label|default(format_date(commission.period_start) ~ ' - ' ~ format_date(commission.period_end)) }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted ps-3">Cash Revenue</th>
                            <td class="text-end pe-3">{{ format_currency(commission.total_cash) }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted ps-3">Card Revenue</th>
                            <td class="text-end pe-3">{{ format_currency(commission.total_card) }}</td>
                        </tr>
                        <tr class="table-light">
                            <th class="ps-3">Gross Revenue</th>
                            <td class="text-end pe-3 fw-medium">{{ format_currency(commission.gross_revenue) }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted ps-3">Transaction Fees</th>
                            <td class="text-end pe-3 text-danger">-{{ format_currency(commission.processing_fees) }}</td>
                        </tr>
                        {% if commission.parts_deduction > 0 %}
                        <tr>
                            <th class="text-muted ps-3">Parts Deduction</th>
                            <td class="text-end pe-3 text-danger">-{{ format_currency(commission.parts_deduction) }}</td>
                        </tr>
                        {% endif %}
                        {% if commission.labour_deduction > 0 %}
                        <tr>
                            <th class="text-muted ps-3">Labour Deduction</th>
                            <td class="text-end pe-3 text-danger">-{{ format_currency(commission.labour_deduction) }}</td>
                        </tr>
                        {% endif %}
                        <tr class="table-light">
                            <th class="ps-3">Net Revenue</th>
                            <td class="text-end pe-3 fw-medium">{{ format_currency(commission.net_revenue) }}</td>
                        </tr>
                        <tr class="table-success">
                            <th class="ps-3 fs-5">Commission Amount</th>
                            <td class="text-end pe-3 fw-bold fs-5">{{ format_currency(commission.commission_amount) }}</td>
                        </tr>
                        {% if commission.total_prepaid > 0 %}
                        <tr>
                            <td colspan="2"><hr class="my-0"></td>
                        </tr>
                        <tr>
                            <th class="text-muted ps-3">Prepaid (tracked separately)</th>
                            <td class="text-end pe-3 text-muted">{{ format_currency(commission.total_prepaid) }}</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Payment Info -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0">Payment Information</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th class="text-muted" style="width: 140px;">Status</th>
                            <td>
                                {% if commission.status == 'paid' %}
                                    <span class="badge bg-success">Paid</span>
                                {% elseif commission.status == 'approved' %}
                                    <span class="badge bg-primary">Approved</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ commission.status|capitalize }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% if commission.paid_at %}
                        <tr>
                            <th class="text-muted">Paid Date</th>
                            <td>{{ format_date(commission.paid_at) }}</td>
                        </tr>
                        {% endif %}
                        {% if commission.payment_reference %}
                        <tr>
                            <th class="text-muted">Reference</th>
                            <td>{{ commission.payment_reference }}</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Revenue by Machine -->
{% if machine_breakdown|length > 0 %}
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-bottom">
        <h6 class="mb-0">Revenue by Machine</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Machine</th>
                        <th class="text-end">Cash</th>
                        <th class="text-end">Card</th>
                        <th class="text-end">Gross</th>
                        <th class="text-end">Fees</th>
                        <th class="text-end">Net</th>
                        <th class="text-center">Rate</th>
                        <th class="text-end">Commission</th>
                    </tr>
                </thead>
                <tbody>
                    {% for m in machine_breakdown %}
                    <tr>
                        <td>
                            <a href="/portal/machines/{{ m.id }}">{{ m.machine_code }}</a>
                            <span class="text-muted small d-block">{{ m.name }}</span>
                        </td>
                        <td class="text-end">{{ format_currency(m.cash_total) }}</td>
                        <td class="text-end">{{ format_currency(m.card_total) }}</td>
                        <td class="text-end">{{ format_currency(m.gross_revenue) }}</td>
                        <td class="text-end text-danger">-{{ format_currency(m.processing_fees) }}</td>
                        <td class="text-end">{{ format_currency(m.net_revenue) }}</td>
                        <td class="text-center"><span class="badge bg-info">{{ m.effective_rate }}%</span></td>
                        <td class="text-end fw-bold">{{ format_currency(m.commission) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td>Total</td>
                        <td class="text-end">{{ format_currency(commission.total_cash) }}</td>
                        <td class="text-end">{{ format_currency(commission.total_card) }}</td>
                        <td class="text-end">{{ format_currency(commission.gross_revenue) }}</td>
                        <td class="text-end text-danger">-{{ format_currency(commission.processing_fees) }}</td>
                        <td class="text-end">{{ format_currency(commission.net_revenue) }}</td>
                        <td></td>
                        <td class="text-end">{{ format_currency(commission.commission_amount) }}</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
