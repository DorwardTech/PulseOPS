{% extends "layouts/portal.twig" %}

{% block title %}Revenue{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Revenue</h4>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" action="/portal/revenue" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="date_from" class="form-label">Date From</label>
                <input type="date" class="form-control" id="date_from" name="date_from" value="{{ filters.date_from }}">
            </div>
            <div class="col-md-3">
                <label for="date_to" class="form-label">Date To</label>
                <input type="date" class="form-control" id="date_to" name="date_to" value="{{ filters.date_to }}">
            </div>
            <div class="col-md-3">
                <label for="machine_id" class="form-label">Machine</label>
                <select class="form-select" id="machine_id" name="machine_id">
                    <option value="">All Machines</option>
                    {% for machine in machines %}
                    <option value="{{ machine.id }}" {{ filters.machine_id == machine.id ? 'selected' : '' }}>{{ machine.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-success me-2">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a href="/portal/revenue" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Revenue Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Machine</th>
                        <th class="text-end">Cash</th>
                        <th class="text-end">Card</th>
                        <th class="text-end">Prepaid</th>
                        <th class="text-end">Total (Cash+Card)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for rev in revenue %}
                    <tr>
                        <td>{{ format_date(rev.collection_date) }}</td>
                        <td>{{ rev.machine_name }}</td>
                        <td class="text-end">{{ format_currency(rev.cash_amount) }}</td>
                        <td class="text-end">{{ format_currency(rev.card_amount) }}</td>
                        <td class="text-end text-muted">{{ format_currency(rev.prepaid_amount) }}</td>
                        <td class="text-end fw-medium">{{ format_currency(rev.cash_amount + rev.card_amount) }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">No revenue records found.</td></tr>
                    {% endfor %}
                </tbody>
                {% if revenue|length > 0 %}
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td colspan="2">Totals</td>
                        <td class="text-end">{{ format_currency(totals.cash) }}</td>
                        <td class="text-end">{{ format_currency(totals.card) }}</td>
                        <td class="text-end text-muted">{{ format_currency(totals.prepaid) }}</td>
                        <td class="text-end">{{ format_currency(totals.cash + totals.card) }}</td>
                    </tr>
                </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
    {% if revenue|length > 0 %}
    <div class="card-footer bg-white border-top">
        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Prepaid is tracked separately and managed by the operator.</small>
    </div>
    {% endif %}
</div>
{% endblock %}
