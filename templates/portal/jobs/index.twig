{% extends "layouts/portal.twig" %}

{% block title %}Jobs{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Jobs</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Job #</th>
                        <th>Title</th>
                        <th>Machine</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Scheduled Date</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for job in jobs %}
                    <tr>
                        <td class="fw-medium">{{ job.id }}</td>
                        <td>
                            <a href="/portal/jobs/{{ job.id }}" class="text-decoration-none">{{ job.title }}</a>
                        </td>
                        <td>{{ job.machine_name }}</td>
                        <td>
                            {% if job.priority == 'critical' %}
                                <span class="badge bg-danger">Critical</span>
                            {% elseif job.priority == 'high' %}
                                <span class="badge bg-warning text-dark">High</span>
                            {% elseif job.priority == 'medium' %}
                                <span class="badge bg-info text-dark">Medium</span>
                            {% else %}
                                <span class="badge bg-secondary">Low</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge" style="background-color: {{ job.status_color }}">{{ job.status_name }}</span>
                        </td>
                        <td>{{ job.scheduled_date ? format_date(job.scheduled_date) : '-' }}</td>
                        <td class="text-end">
                            <a href="/portal/jobs/{{ job.id }}" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No jobs found for your machines.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
