{% extends "layouts/auth.twig" %}

{% block title %}Customer Portal Login{% endblock %}
{% block subtitle %}Customer Portal{% endblock %}

{% block content %}
<form method="POST" action="/portal/login">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    <div class="mb-3">
        <label for="email" class="form-label">Email Address</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" class="form-control" id="email" name="email" value="{{ old_email }}" required autofocus>
        </div>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" class="form-control" id="password" name="password" required>
        </div>
    </div>

    <button type="submit" class="btn btn-success w-100 py-2">
        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In to Portal
    </button>
</form>
{% endblock %}
