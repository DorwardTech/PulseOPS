{% extends "layouts/portal.twig" %}

{% block title %}Report Issue - {{ machine.name }}{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portal/machines" class="text-decoration-none">Machines</a></li>
        <li class="breadcrumb-item"><a href="/portal/machines/{{ machine.id }}" class="text-decoration-none">{{ machine.name }}</a></li>
        <li class="breadcrumb-item active">Report Issue</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Report an Issue</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">
                    Report an issue with <strong>{{ machine.name }}</strong> ({{ machine.code }}). Our team will review and schedule maintenance as needed.
                </p>

                <form method="POST" action="/portal/machines/{{ machine.id }}/report-issue">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-3">
                        <label for="title" class="form-label">Issue Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="title" value="{{ old_title }}" required placeholder="Brief description of the issue">
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="description" name="description" rows="5" required placeholder="Please describe the issue in detail, including any error messages or unusual behaviour...">{{ old_description }}</textarea>
                    </div>

                    <div class="mb-4">
                        <label for="priority" class="form-label">Priority <span class="text-danger">*</span></label>
                        <select class="form-select" id="priority" name="priority" required>
                            <option value="">Select priority...</option>
                            <option value="low" {{ old_priority == 'low' ? 'selected' : '' }}>Low - Minor issue, machine still operational</option>
                            <option value="medium" {{ old_priority == 'medium' ? 'selected' : '' }}>Medium - Machine partially affected</option>
                            <option value="high" {{ old_priority == 'high' ? 'selected' : '' }}>High - Machine significantly impacted</option>
                            <option value="critical" {{ old_priority == 'critical' ? 'selected' : '' }}>Critical - Machine not operational</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-send me-1"></i>Submit Issue Report
                        </button>
                        <a href="/portal/machines/{{ machine.id }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
