# PulseOPS V3 Environment Configuration
# Copy to .env and update values

# Application
APP_NAME="PulseOPS"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=Australia/Darwin

# Database (MariaDB)
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=pulseops
DB_USERNAME=pulseops
DB_PASSWORD=secret
DB_CHARSET=utf8mb4

# Nayax API
NAYAX_API_URL=https://lynx.nayax.com
NAYAX_API_TOKEN=
NAYAX_OPERATOR_ID=
NAYAX_ENVIRONMENT=production

# Cron Security
CRON_KEY=change-this-to-a-secure-random-string

# SMTP (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PulseOPS
